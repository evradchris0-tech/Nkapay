{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "baseUrl": "./src",
    "paths": {
      "@config/*": ["config/*"],
      "@modules/*": ["modules/*"],
      "@shared/*": ["shared/*"],
      "@utils/*": ["shared/utils/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests", "src/modules/exercices/services/*", "src/modules/exercices/dto/exercice-membre.dto.ts", "src/modules/tontines/services/*", "src/modules/tontines/dto/adhesion-tontine.dto.ts", "src/modules/tontines/dto/rule-definition.dto.ts", "src/modules/tontines/controllers/rule-definition.controller.ts", "src/modules/penalites/services/type-penalite.service.ts", "src/modules/reunions/services/*", "src/modules/secours/services/*"]
}
